# ─── Required ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/edustack?retryWrites=true&w=majority
JWT_SECRET=                    # min 32 chars, use: openssl rand -base64 32
JWT_REFRESH_SECRET=            # min 32 chars, different from JWT_SECRET
FRONTEND_URL=https://yourdomain.vercel.app

# ─── Optional (defaults shown) ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # development | production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BASE_DOMAIN=edustack.pk        # used for subdomain-based tenant routing
VERCEL_PREVIEW_URL=            # specific preview URL to whitelist in CORS

# ─── AWS S3 (optional — file upload features disabled if not set) ─────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=edustack-uploads
